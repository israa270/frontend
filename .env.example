# Supabase project URL (no trailing slash)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase publishable / anon public key (safe for browser)
VITE_SUPABASE_ANON_KEY=

# Optional: for server-side scripts, CLI, or migrations only (never VITE_*)
# SUPABASE_PROJECT_ID=
# SUPABASE_SECRET_KEY=
# SUPABASE_DB_PASSWORD=
# SMTP_EMAIL=
# SMTP_APP_PASSWORD=
